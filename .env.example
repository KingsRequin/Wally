# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-...

# ===== tools openai =======
# tavily
TAVILY_API_KEY=tvly-...
APEX_API_KEY=xxx

# Discord
DISCORD_TOKEN=
# Serveur principal : sync des commandes + perception de la présence des membres
# (statut/activité, lecture seule). Requiert l'intent privilégié "Presence Intent"
# activé dans le portail développeur Discord.
DISCORD_GUILD_ID=

# Twitch — identifiants OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# IDs numériques
TWITCH_BROADCASTER_ID=
TWITCH_BOT_ID=
TWITCH_BOT_NICK=wallybot

# Token du compte bot (scopes: user:read:chat user:write:chat user:bot moderator:read:followers)
BOT_ACCESS_TOKEN=
BOT_REFRESH_TOKEN=

# Token du compte streamer (scopes: bits:read channel:read:subscriptions)
STREAMER_ACCESS_TOKEN=
STREAMER_REFRESH_TOKEN=

# chat en ligne
# https://discord.com/developers/applications/
# OAuth2 -> Identifiant du client
DISCORD_CLIENT_ID=...
# Clé secrète du client
DISCORD_CLIENT_SECRET=...
# URL de redirection (doit correspondre à celle configurée dans l'application Discord)
WEB_BASE_URL=https://ton-domaine.com
# Token pour Cloudflared (si tu utilises un tunnel pour exposer ton application localement)
CLOUDFLARED_WALLY_TOKEN=

# Qdrant (internal Docker network)
QDRANT_URL=http://qdrant:6333

# token pour signer les JWT (doit être une chaîne secrète et complexe aleatoire), tu peut la générer avec une commande comme `openssl rand -hex 32`
JWT_SECRET=...

# Database path (inside container)
DB_PATH=data/wally.db

# Langfuse (LLM observability)
# URL externe accessible depuis le navigateur (ex: via un second hostname Cloudflare Tunnel)
# Laissée vide → le tab dashboard affiche des instructions de configuration
LANGFUSE_EXTERNAL_URL=
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_DB_PASSWORD=langfuse_secret
LANGFUSE_NEXTAUTH_SECRET=change-me-random-32-chars
LANGFUSE_SALT=change-me-random-32-chars
LANGFUSE_INIT_USER_EMAIL=admin@wally.local
LANGFUSE_INIT_USER_PASSWORD=change-me
