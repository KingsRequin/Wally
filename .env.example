# OpenAI
OPENAI_API_KEY=sk-...


# ===== tools openai =======
# tavily
TAVILY_API_KEY=tvly-...
APEX_API_KEY=xxx

# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Twitch — identifiants OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# IDs numériques
TWITCH_BROADCASTER_ID=
TWITCH_BOT_ID=
TWITCH_BOT_NICK=wallybot

# Token du compte bot (scopes: user:read:chat user:write:chat user:bot moderator:read:followers)
BOT_ACCESS_TOKEN=
BOT_REFRESH_TOKEN=

# Token du compte streamer (scopes: bits:read channel:read:subscriptions)
STREAMER_ACCESS_TOKEN=
STREAMER_REFRESH_TOKEN=

# chat en ligne
# https://discord.com/developers/applications/
# OAuth2 -> Identifiant du client
DISCORD_CLIENT_ID=...
# Clé secrète du client
DISCORD_CLIENT_SECRET=...
# URL de redirection (doit correspondre à celle configurée dans l'application Discord)
WEB_BASE_URL=https://ton-domaine.com
# Token pour Cloudflared (si tu utilises un tunnel pour exposer ton application localement)
CLOUDFLARED_WALLY_TOKEN=

# Qdrant (internal Docker network)
QDRANT_URL=http://qdrant:6333

# Database path (inside container)
DB_PATH=data/wally.db
